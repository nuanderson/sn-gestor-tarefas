# ──────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────

DEBUG=True
SECRET_KEY=troque-por-uma-chave-secreta-forte
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=sn_gestor
POSTGRES_USER=sn_user
POSTGRES_PASSWORD=sua_senha_aqui
POSTGRES_HOST=db
POSTGRES_PORT=5432

TIME_ZONE=America/Sao_Paulo

# ── E-mail SMTP (Gmail) ────────────────────────
# Para Gmail: ative "Senhas de app" em myaccount.google.com/security
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seuemail@gmail.com
EMAIL_HOST_PASSWORD=sua_senha_de_app_aqui
DEFAULT_FROM_EMAIL=SN Gestor <seuemail@gmail.com>

# ── Conta Azul OAuth 2.0 ──────────────────────
# Credenciais do portal de desenvolvedores: https://developers-portal.contaazul.com
CONTAAZUL_CLIENT_ID=seu_client_id_aqui
CONTAAZUL_CLIENT_SECRET=seu_client_secret_aqui
# Em desenvolvimento: http://localhost/contaazul/callback/
# Em produção: https://seudominio.com.br/contaazul/callback/
CONTAAZUL_REDIRECT_URI=http://localhost/contaazul/callback/
